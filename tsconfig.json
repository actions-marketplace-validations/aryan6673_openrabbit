{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ES2020",
    "moduleResolution": "Bundler",
    "lib": ["ES2023", "DOM"],
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "declaration": true
  },
  "include": ["src"]
}
